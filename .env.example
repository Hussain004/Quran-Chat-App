# ============================================================
# Qur'an Chat App — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ============================================================

# --- Supabase ---
# Found at: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # "service_role" key (secret — keep private)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # "anon" key (safe for client)

# --- Groq (chat generation — free tier, 14,400 req/day, no card required) ---
# Sign up at: console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_...

# --- Jina AI (embeddings — 1M free tokens/month, no card required) ---
# Sign up at: jina.ai → copy your API key
JINA_API_KEY=jina_...

# --- Expo app (prefix with EXPO_PUBLIC_ so the RN bundler includes them) ---
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=...

# --- Vercel API (set these in the Vercel dashboard, not here) ---
# SUPABASE_URL, SUPABASE_SERVICE_KEY, GEMINI_API_KEY, JINA_API_KEY
